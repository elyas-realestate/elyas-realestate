# ========================================
# Wasit Pro — .gitignore
# آخر تحديث: ١١ مايو ٢٠٢٦
# ========================================

# ---- المتغيرات السرية والبيئات (الأهم) ----
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Secrets / Keys / Credentials ----
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/
service-account*.json
*-credentials.json

# ---- Next.js ----
.next/
out/
build/
dist/

# ---- Node ----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- Testing ----
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# ---- IDE / Editors ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.swp
*.swo
*~
.cursorignore
.cursorrules

# ---- Operating System ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Deployment / Build tools ----
.vercel/
.turbo/
.cache/
.parcel-cache/

# ---- Supabase ----
supabase/.branches/
supabase/.temp/
supabase/.env

# ---- Logs ----
logs/
*.log

# ---- Misc ----
.eslintcache
.stylelintcache
tmp/
temp/
*.bak
*.backup

# ---- Project-specific exclusions ----
# ملف static HTML قديم — لا داعي لتتبّعه
wasit-pro-landing.html

# script محلي
write.js

# ---- Claude Code local settings (نحتفظ بـ .claude/memory/ في git) ----
.claude/launch.json
.claude/settings.local.json
# لا نتجاهل .claude/memory/ — لأنها ذاكرة المشروع المفيدة
